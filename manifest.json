{
  "manifest_version": 3,
  "name": "Daily History Digest",
  "version": "1.0.0",
  "description": "Export today's browsing history as markdown for Obsidian PKM.",
  "permissions": ["history", "downloads", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Daily History Digest",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
